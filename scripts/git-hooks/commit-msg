#!/bin/sh
# Strip editor/tool attribution trailers from commit messages (repo policy: no credit lines).
# Some environments append "Made-with: Cursor" after the author message; remove it in-place.
# Install: cp scripts/git-hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg
msg_file="$1"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
	exit 0
fi
tmp="${msg_file}.strip.$$"
# Drop CRLF for matching; drop whole lines matching Cursor attribution (same patterns as before).
tr -d '\r' < "$msg_file" | grep -viE '^[[:space:]]*(made-with|made[[:space:]]+with):[[:space:]]*cursor[[:space:]]*$' > "$tmp" || true
mv -f "$tmp" "$msg_file"
exit 0
