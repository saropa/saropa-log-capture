    "viewports",
    "visibilitychange",
    "vscodeignore",
    "vsixignore",
    "winget",
    "Wireshark",
    "workstream",
    "ZWSP"
  ],
  "chat.tools.terminal.autoApprove": {
    "git add": true,
    "git commit": true
  },
  "saropaLogCapture.captureAll": false,
  "saropaLogCapture.exclusions": [
    "  [PASS] Dependencies                  1.9s"
  ],
  "saropaLogCapture.watchPatterns": [
    {
      "keyword": "error",
      "alert": "flash"
    },
    {
      "keyword": "exception",
      "alert": "flash"
    },
    {
      "keyword": "warning",
      "alert": "badge"
    }
  ],
  "saropaLogCapture.integrations.adapters": [
    "packages",
    "git",
    "environment",
    "browser"
  ]
}
