// Place your settings in this file to overwrite default and user settings.
{
  "files.watcherExclude": { "**/.vscode-test/**": true },
  "files.exclude": {
    "out": false, // set this to true to hide the "out" folder with the compiled JS files
    "dist": false, // set this to true to hide the "dist" folder with the compiled JS files
    "**/.vscode-test/**": true // hide the multi-GB @vscode/test-electron download cache from the Explorer
  },
  "search.exclude": {
    "out": true, // set this to false to include "out" folder in search results
    "dist": true, // set this to false to include "dist" folder in search results
    "**/.vscode-test/**": true // keep the test-runner VS Code installs out of search/TS indexing
  },
  // Turn off tsc task auto detection since we have the necessary tasks as npm scripts
  "typescript.tsc.autoDetect": "off",
  "cSpell.words": [
    "Affordances",
    "basenames",
    "blockquotes",
    "borderless",
    "BRDA",
    "checkmarks",
    "clippy",
    "codegen",
    "colorama",
    "Cooldown",
    "cpuprofile",
    "ctranslate",
    "dartdoc",
    "debuggee",
    "Dedup",
    "Deduplicator",
    "deeplink",
    "Deutsch",
    "devlog",
    "drilldown",
    "drilldowns",
    "dups",
    "ECONNREFUSED",
    "ellipsized",
    "esbuild",
    "Fintech",
    "flyouts",
    "flyup",
    "FNDA",
    "Frederik",
    "geninfo",
    "Geolocator",
    "getx",
    "gralloc",
    "grayscale",
    "hotfile",
    "hotfiles",
    "huggingface",
    "HWUI",
    "idevicesyslog",
    "inlines",
    "inspectable",
    "invisibles",
    "Jaccard",
    "jank",
    "journalctl",
    "keyup",
    "Kykto",
    "linecap",
    "linejoin",
    "linkification",
    "linkified",
    "linkifier",
    "linkify",
    "logcat",
    "Logz",
    "lookarounds",
    "lookback",
    "lostpointercapture",
    "microtask",
    "misaligns",
    "mousedown",
    "mousemove",
    "mouseup",
    "myapp",
    "NLLB",
    "nonced",
    "oneline",
    "OPENVSX",
    "overscan",
    "OVSX",
    "pasteable",
    "perfs",
    "playcore",
    "pointercancel",
    "pointerdown",
    "pointermove",
    "pointerup",
    "popout",
    "Prefixless",
    "prereqs",
    "PROCESSLIST",
    "pubspec",
    "rebindable",
    "recalc",
    "Redactions",
    "Rescan",
    "Rescanning",
    "Retarget",
    "RGBA",
    "rollups",
    "runningboard",
    "sandboxed",
    "Saropa",
